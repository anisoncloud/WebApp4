@model IEnumerable<WebApplication4.Dto.CategoryDto>
@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
}

<table class="table">
    <thead>
        <tr>
            <th scope="col">#</th>
            <th scope="col">Name</th>
            <th scope="col">Details</th>
            <th scope="col">Action</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <th scope="row">1</th>
                <td>@item.Name</td>
                <td>@item.Description</td>
                <td>
                    <a asp-action="" asp-route-id="@item.Id" class="btn btn-primary btn-sm p-1">View</a>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-primary btn-sm p-1">Edit</a>
                    <form asp-action="Delete" asp-route-id="@item.Id" method="post">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-primary btn-sm p-1">Delete</button>
                    </form>

                </td>
            </tr>
        }

        
    </tbody>
</table>