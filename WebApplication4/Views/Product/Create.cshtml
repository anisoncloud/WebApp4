@model WebApplication4.ViewModels.ProductFormViewModel
@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
}
<form asp-action="Create">
    @Html.AntiForgeryToken()
    <div class="text text-danger" asp-validation-summary="ModelOnly"></div>
    <!-- Category Checkboxes -->
    <div class="category-list" id="categoryList">
        @foreach (var category in Model.CategoryOptions)
        {
            <label class="category-item" data-name="@category.Text.ToLower()">
                <input type="checkbox"
                       name="SelectedCategoryIds"
                       value="@category.Value"
                       class="category-checkbox"
                @(category.Selected ? "checked" : "") />
                <span class="category-checkmark">
                    <i class="bi bi-check"></i>
                </span>
                <span class="category-name">@category.Text</span>
                @if (category.Selected)
                {
                    <span class="current-badge">Current</span>
                }
            </label>
        }
    </div>

    <span asp-validation-for="SelectedCategoryIds" class="text text-danger"></span>
    <div class="mb-3">
        <label for="exampleFormControlInput1" class="form-label">Name</label>
        <input asp-for="Name" type="text" class="form-control" id="exampleFormControlInput1" placeholder="Product Name">
    </div>
    <div class="mb-3">
        <label for="exampleFormControlTextarea1" class="form-label">Description</label>
        <textarea asp-for="Description" class="form-control" id="exampleFormControlTextarea1" rows="3"></textarea>
    </div>
    <button type="submit" class="btn btn-primary">Create Product</button>
</form>